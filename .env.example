# Скопируйте в .env и заполните. .env в git НЕ коммитится (см. .gitignore).

# Ключ баунсера. Сгенерировать ПОСЛЕ первого старта crowdsec:
#   docker compose up -d crowdsec
#   docker exec crowdsec cscli bouncers add mikrotik-bouncer
BOUNCER_KEY=ВСТАВЬТЕ_КЛЮЧ_ОТ_CSCLI

# Роутер MikroTik
ROUTER_IP=192.0.2.1                 # LAN-адрес роутера (API 8728)
MIKROTIK_USER=crowdsec-bouncer-user
MIKROTIK_PASS=ДЛИННЫЙ_СЛУЧАЙНЫЙ_ПАРОЛЬ
